<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Push Notifications capability (APNs). `development` is correct for
	  TestFlight/dev builds; Xcode/Archive promotes it to `production` for the
	  App Store automatically. This file is linked to the App target by adding
	  the "Push Notifications" capability in Xcode → Signing & Capabilities
	  (which sets CODE_SIGN_ENTITLEMENTS = App/App.entitlements). See the operator
	  steps in docs/handoffs/HANDOFF_CURRENT.md.
	-->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
