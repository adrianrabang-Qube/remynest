# RemyNest E2E (Playwright) — example test environment
# Copy to .env.test (git-ignored) and fill with DEDICATED TEST ACCOUNTS ONLY.
# Never use real user data. Never commit real values.

# Optional: test against a deployed URL instead of the local dev server.
# When set, Playwright will NOT start `npm run dev`.
# E2E_BASE_URL=https://staging.remynest.example

# --- Owner account (Profile Switching Data Isolation test) ---
E2E_OWNER_EMAIL=
E2E_OWNER_PASSWORD=

# --- Caregiver account (Caregiver IDOR test) ---
E2E_CAREGIVER_EMAIL=
E2E_CAREGIVER_PASSWORD=

# --- Seeded isolation targets ---
# A profile the above accounts must NOT be able to access (another tenant).
E2E_FOREIGN_PROFILE_ID=
# A memory that lives inside a non-shared profile (for the direct-URL IDOR check).
E2E_FOREIGN_MEMORY_ID=
