# RemyNest — required runtime environment variables (RC4).
# Copy to .env.local for local dev and set the real values in Vercel for prod.
# Placeholders only — NEVER commit real secrets. Grouped by subsystem; the notes
# say what degrades if a var is missing (most features fail safe, so a missing var
# is silent feature loss rather than a build error — hence this reference file).

# ── Supabase (database, auth, storage) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — SERVER ONLY, bypasses RLS. Required for admin/service paths
# (GDPR export/delete, storage ledger, AI usage, caregiver reconcile). Never expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (web checkout only; no native purchase UI, Apple 3.1.1) ─────────────
STRIPE_SECRET_KEY=sk_live_or_test_...
# Webhook signing secret — required for signature verification on /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ids used by checkout (lib/billing/plans.ts reads these EXACT names — one per
# plan × interval). Premium + Family are the launch tiers, so their 4 ids are required
# for the premium-upgrade flow to resolve a price; without them checkout can't upgrade.
# Enterprise is post-launch (leave unset until sold).
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...
STRIPE_FAMILY_MONTHLY_PRICE_ID=price_...
STRIPE_FAMILY_YEARLY_PRICE_ID=price_...
# STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
# STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_...

# ── OpenAI (AI features: Ask Remy, embeddings, summaries, story narration) ─────
OPENAI_API_KEY=sk-...
# Optional model override (defaults in code).
# OPENAI_MODEL=gpt-4o-mini

# ── OneSignal (push notifications) ────────────────────────────────────────────
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
# REST API key — SERVER ONLY (used by the reminder cron to send pushes).
ONESIGNAL_API_KEY=your-onesignal-rest-api-key

# ── Cron (Vercel Scheduled Functions) ─────────────────────────────────────────
# REQUIRED: the reminder cron fails CLOSED (401) if unset. Vercel sends it as
# `Authorization: Bearer <CRON_SECRET>` on each scheduled invocation.
CRON_SECRET=a-long-random-string

# ── Sentry (error/crash diagnostics) ──────────────────────────────────────────
# No-op until a DSN is set (enabled: Boolean(dsn)). Session Replay is disabled;
# PII is scrubbed (sendDefaultPii:false + beforeSend). Safe to leave unset in dev.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source-map upload at build time (optional; upload is skipped if unset).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── App-store download links (public; drive the /download page) ───────────────
# Read by app/download/page.tsx. If unset, the corresponding store button is empty
# (page degrades, no error). Set the iOS link at launch; Play is post-iOS.
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# ── Feature flags / operator gates ────────────────────────────────────────────
# Supabase Image Transformations (Pro plan). Default OFF = byte-identical baseline.
MEMORY_IMAGE_TRANSFORMS_ENABLED=false

# ── GDPR account-deletion tombstone (retain-mode) ─────────────────────────────
# A real auth user id used to tombstone cross-contributed memories on deletion.
# Required only for the retain (deleteContributed=false) deletion path.
TOMBSTONE_USER_ID=
